{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": ["src/**/*.{ts,tsx}"],
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "src/components/ui/**",
    "src/constants/**"
  ],
  "duplicates": {
    "minOccurrences": 3,
    "ignore": ["src/components/ui/**"]
  },

  "rules": {
    "unused-dependencies": "warn"
  }
}
